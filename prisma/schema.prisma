generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================== AUTH ===================
model User {
  id        String    @id @default(cuid())
  name      String?
  email     String?   @unique
  password  String?
  role      String    @default("staff")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
  messages  Message[]
}

// =================== STAFF ===================
model Staff {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  role        String   @default("Sales")
  status      String   @default("Active")
  password    String?
  joinDate    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Permissions
  canViewDashboard    Boolean @default(true)
  canViewOrders       Boolean @default(true)
  canConfirmOrders    Boolean @default(false)
  canViewMessages     Boolean @default(true)
  canReplyMessages    Boolean @default(true)
  canViewStaff        Boolean @default(false)
  canManageStaff      Boolean @default(false)
  canViewCourier      Boolean @default(false)
  canManageCourier    Boolean @default(false)
  canViewReports      Boolean @default(false)
  canViewPnL          Boolean @default(false)
  canCreateContent    Boolean @default(false)
  canPostContent      Boolean @default(false)
  canViewSettings     Boolean @default(false)
  canManageDaraz      Boolean @default(false)
}

// =================== ORDERS ===================
model Order {
  id           String   @id @default(cuid())
  orderId      String   @unique
  customerName String
  phone        String
  address      String?
  product      String
  quantity     Int      @default(1)
  price        Float
  status       String   @default("Pending")
  courier      String?
  trackingNo   String?
  platform     String?
  staffId      String?
  staff        User?    @relation(fields: [staffId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Daraz fields (future)
  darazOrderId   String?
  darazStatus    String?
  darazPlatform  String?
}

// =================== MESSAGES ===================
model Message {
  id         String   @id @default(cuid())
  platform   String
  senderId   String
  senderName String
  pageId     String?
  message    String
  timestamp  DateTime @default(now())
  status     String   @default("new")
  isFromUs   Boolean  @default(false)
  aiReplied  Boolean  @default(false)
  replied    Boolean  @default(false)
  replyText  String?
  staffId    String?
  staff      User?    @relation(fields: [staffId], references: [id])
  createdAt  DateTime @default(now())
}

// =================== FOLLOWUP ===================
model Followup {
  id           String   @id @default(cuid())
  customerName String
  phone        String
  platform     String
  lastMsg      String?
  followupDate String
  status       String   @default("Upcoming")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// =================== SHIPMENT ===================
model Shipment {
  id        String   @id @default(cuid())
  orderId   String
  customer  String
  phone     String
  product   String
  courier   String
  tracking  String?
  status    String   @default("Pending Pickup")
  charge    Float    @default(0)
  estimated String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =================== CONTENT ===================
model Content {
  id          String   @id @default(cuid())
  title       String
  body        String
  platform    String   // facebook, instagram, tiktok
  status      String   @default("draft") // draft, scheduled, posted
  scheduledAt DateTime?
  postedAt    DateTime?
  staffId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =================== P&L ===================
model Transaction {
  id          String   @id @default(cuid())
  type        String   // income, expense
  category    String   // order, courier, salary, ads, other
  amount      Float
  description String?
  date        DateTime @default(now())
  staffId     String?
  createdAt   DateTime @default(now())
}

// =================== DARAZ (Future) ===================
model DarazStore {
  id          String   @id @default(cuid())
  storeName   String
  sellerId    String?
  accessToken String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DarazOrder {
  id            String   @id @default(cuid())
  darazOrderId  String   @unique
  customerName  String
  product       String
  quantity      Int      @default(1)
  price         Float
  status        String
  trackingNo    String?
  returnStatus  String?
  paymentStatus String?
  storeId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
// =================== ACTIVITY LOG ===================
model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // message_reply, order_confirm, login, logout, staff_add, etc.
  description String
  entityType  String?  // message, order, staff, etc.
  entityId    String?
  performedBy String   // staff id वा "AI" वा "system"
  staffName   String?  // display name
  isAI        Boolean  @default(false)
  metadata    String?  // JSON string — extra info
  createdAt   DateTime @default(now())
}
// =================== PRODUCTS ===================
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  salePrice   Float?
  stock       Int      @default(0)
  images      String?  // JSON array of image URLs
  videoUrl    String?
  features    String?  // JSON array
  usage       String?
  implications String?
  category    String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =================== AD CAMPAIGNS ===================
model AdCampaign {
  id            String   @id @default(cuid())
  name          String
  platform      String   @default("facebook")
  adId          String?  // Facebook Ad ID
  productId     String?
  budget        Float    @default(0)
  spent         Float    @default(0)
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  expenses      AdExpense[]
  orders        AdOrder[]
}

model AdExpense {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id])
  type        String   // ad_spend, ai_reply, shipping, exchange, failed_delivery, other
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model AdOrder {
  id            String   @id @default(cuid())
  campaignId    String?
  campaign      AdCampaign? @relation(fields: [campaignId], references: [id])
  orderId       String?
  revenue       Float    @default(0)
  shippingCost  Float    @default(0)
  productCost   Float    @default(0)
  aiCost        Float    @default(0)
  otherCost     Float    @default(0)
  status        String   @default("Pending") // Pending, Delivered, Failed, Exchanged
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =================== AI CONVERSATIONS ===================
model AIConversation {
  id          String   @id @default(cuid())
  senderId    String
  pageId      String?
  platform    String
  messages    String   // JSON array of conversation history
  stage       String   @default("greeting") // greeting, product_info, collecting_order, confirmed
  orderData   String?  // JSON: naam, phone, address
  productId   String?
  campaignId  String?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}