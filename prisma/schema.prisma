generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  password       String?
  role           String    @default("staff")
  subscriptionId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  orders         Order[]
  messages       Message[]
}

model Staff {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  phone            String?
  role             String   @default("Sales")
  status           String   @default("Active")
  password         String?
  joinDate         String?
  subscriptionId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  canViewDashboard    Boolean @default(true)
  canViewOrders       Boolean @default(true)
  canConfirmOrders    Boolean @default(false)
  canViewMessages     Boolean @default(true)
  canReplyMessages    Boolean @default(true)
  canViewStaff        Boolean @default(false)
  canManageStaff      Boolean @default(false)
  canViewCourier      Boolean @default(false)
  canManageCourier    Boolean @default(false)
  canViewReports      Boolean @default(false)
  canViewPnL          Boolean @default(false)
  canCreateContent    Boolean @default(false)
  canPostContent      Boolean @default(false)
  canViewSettings     Boolean @default(false)
  canManageDaraz      Boolean @default(false)
}

model Order {
  id                     String   @id @default(cuid())
  orderId                String   @unique
  customerName           String
  phone                  String
  address                String?
  product                String
  quantity               Int      @default(1)
  price                  Float
  costPrice              Float?
  shippingCharge         Float?
  customerShippingCharge Float?
  status                 String   @default("Pending")
  courier                String?
  trackingNo             String?
  platform               String?
  senderId               String?
  campaignId             String?
  adId                   String?
  pageId    String?
  pageName  String?
  isSameDay              Boolean  @default(false)
  isCancelledAtDoor      Boolean  @default(false)
  isExchange             Boolean  @default(false)
  isFailedDelivery       Boolean  @default(false)
  staffId                String?
  staff                  User?    @relation(fields: [staffId], references: [id])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  darazOrderId           String?
  darazStatus            String?
  darazPlatform          String?
}

model Message {
  id         String   @id @default(cuid())
  platform   String
  senderId   String
  senderName String
  pageId     String?
  message    String
  timestamp  DateTime @default(now())
  status     String   @default("new")
  isFromUs   Boolean  @default(false)
  aiReplied  Boolean  @default(false)
  replied    Boolean  @default(false)
  replyText  String?
  staffId    String?
  staff      User?    @relation(fields: [staffId], references: [id])
  createdAt  DateTime @default(now())
}

model Followup {
  id           String   @id @default(cuid())
  customerName String
  phone        String
  platform     String
  lastMsg      String?
  followupDate String
  status       String   @default("Upcoming")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Shipment {
  id        String   @id @default(cuid())
  orderId   String
  customer  String
  phone     String
  product   String
  courier   String
  tracking  String?
  status    String   @default("Pending Pickup")
  charge    Float    @default(0)
  estimated String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Content {
  id          String    @id @default(cuid())
  title       String
  body        String
  platform    String
  status      String    @default("draft")
  scheduledAt DateTime?
  postedAt    DateTime?
  staffId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  description String?
  date        DateTime @default(now())
  staffId     String?
  createdAt   DateTime @default(now())
}

model DarazStore {
  id           String    @id @default(cuid())
  storeName    String
  sellerId     String?   @unique
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  isActive     Boolean   @default(true)
  status       String    @default("Active")
  lastOrderFetch  DateTime?
  lastReturnFetch DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model DarazOrder {
  id            String   @id @default(cuid())
  darazOrderId  String   @unique
  customerName  String
  product       String
  quantity      Int      @default(1)
  price         Float
  status        String
  trackingNo    String?
  returnStatus  String?
  paymentStatus String?
  storeId       String?
  orderDate     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  description String
  entityType  String?
  entityId    String?
  performedBy String
  staffName   String?
  isAI        Boolean  @default(false)
  metadata    String?
  createdAt   DateTime @default(now())
}

model Product {
  id           String   @id @default(cuid())
  name         String
  description  String?
  price        Float
  salePrice    Float?
  costPrice    Float?
  stock        Int      @default(0)
  images       String?
  videoUrl     String?
  features     String?
  usage        String?
  implications String?
  category     String?
  weightKg     Float    @default(0)
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdCampaign {
  id        String      @id @default(cuid())
  name      String
  platform  String      @default("facebook")
  adId      String?
  productId String?
  budget    Float       @default(0)
  spent     Float       @default(0)
  startDate DateTime?
  endDate   DateTime?
  status    String      @default("Active")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  expenses  AdExpense[]
  orders    AdOrder[]
}

model AdExpense {
  id          String     @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id])
  type        String
  amount      Float
  description String?
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())
}

model AdOrder {
  id                     String      @id @default(cuid())
  campaignId             String?
  campaign               AdCampaign? @relation(fields: [campaignId], references: [id])
  orderId                String?
  adId                   String?
  revenue                Float       @default(0)
  shippingCost           Float       @default(0)
  customerShippingCharge Float       @default(0)
  productCost            Float       @default(0)
  costPrice              Float       @default(0)
  salePrice              Float       @default(0)
  aiCost                 Float       @default(0)
  otherCost              Float       @default(0)
  status                 String      @default("Pending")
  isFailedDelivery       Boolean     @default(false)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
}

model AIConversation {
  id         String   @id @default(cuid())
  senderId   String
  pageId     String?
  platform   String
  messages   String
  stage      String   @default("greeting")
  orderData  String?
  productId  String?
  campaignId String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  priceMonthly  Float
  priceYearly   Float
  maxPages      Int            @default(1)
  maxStaff      Int            @default(2)
  aiReply       Boolean        @default(true)
  darazAccess   Boolean        @default(false)
  reportsAccess Boolean        @default(false)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
}

model Subscription {
  id               String    @id @default(cuid())
  businessName     String
  email            String    @unique
  phone            String?
  planId           String
  plan             Plan      @relation(fields: [planId], references: [id])
  status           String    @default("Trial")
  billingCycle     String    @default("monthly")
  trialEndsAt      DateTime
  currentPeriodEnd DateTime
  pagesConnected   Int       @default(0)
  staffCount       Int       @default(0)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  payments         Payment[]
}

model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  amount         Float
  method         String
  status         String       @default("Pending")
  reference      String?
  paidAt         DateTime?
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime     @default(now())
}
model DarazScan {
  id           String   @id @default(cuid())
  darazOrderId String
  productName  String
  scanType     String
  quantity     Int      @default(1)
  scannedBy    String?
  notes        String?
  trackingNo   String?
  itemName     String?
  price        Float?
  customerName String?
  createdAt    DateTime @default(now())
}

model DarazAlert {
  id           String    @id @default(cuid())
  darazOrderId String
  productName  String
  alertType    String
  status       String    @default("unresolved")
  notes        String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
}




model DarazClaim {
  id              String    @id @default(cuid())
  trackingNo      String
  darazOrderId    String?
  itemName        String?
  price           Float?
  customerName    String?
  quantity        Int       @default(1)
  returnType      String?
  customerComment String?
  qcComment       String?
  staffClaim      String?
  claimResult     String?
  claimStatus     String    @default("pending")
  scannedBy       String?
  resolvedAt      DateTime?
  storeId         String?
  orderDate       DateTime?
    itemCondition   String?
    claimReason     String?
    claimType       String?
    claimedAmount   Float?
    receivedAmount  Float?
    claimDate       DateTime?
    claimNote       String?
    claimDecision   String?   @default("undecided")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
